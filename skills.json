[
    {
        "name": "NavTo",
        "input_ports": [
            {"name": "robot_name", "type":"string"}, 
            {"name": "x", "type":"double"}, 
            {"name": "y", "type":"double"}, 
            {"name":"tolerance","type":"double"}
        ],
        "output_ports": [
            {"name":"success","type":"bool"},
            {"name":"message","type":"string"}
        ],
        "description": "Navigate the robot to (x, y).",
        "preconditions": "None",
        "effects": [
            "robot move to (x, y)"
        ]
    },   
    {
        "name": "Pick",
        "input_ports": [
            {"name":"robot_name","type":"string"}, 
            {"name":"object_name","type":"string"}
        ],
        "output_ports": [
            {"name":"success","type":"bool"},
            {"name":"message","type":"string"}
        ],
        "description": "Make the robot pick up a graspable object.",
        "preconditions": [
        "robot is not holding any object",
        "object is graspable by robot"
        ],
        "effects": [
        "robot is holding the object"
        ]
    },
    {
        "name": "Place",
        "input_ports": [
            {"name":"robot_name","type":"string"}, 
            {"name":"object_name","type":"string"}, 
            {"name":"location_name","type":"string"}
        ],
        "output_ports": [
            {"name":"success","type":"bool"},
            {"name":"message","type":"string"}
        ],
        "description": "Place the robot's currently holding object onto a target object or target position.",
        "preconditions": [
        "robot is holding the object"
        ],
        "effects": [
        "robot no longer holds the object"
        ]
    }
]
